{
  "name": "virtual-event-management-platform",
  "version": "1.0.0",
  "description": "virtual event management platform",
  "homepage": "https://github.com/mohankumar-markuli/Virtual-Event-Management-Platform#readme",
  "bugs": {
    "url": "https://github.com/mohankumar-markuli/Virtual-Event-Management-Platform/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohankumar-markuli/Virtual-Event-Management-Platform.git"
  },
  "license": "ISC",
  "author": "mohankumar",
  "type": "commonjs",
  "main": "index.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "start": "node src/server.js",
    "dev": "nodemon src/server.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2",
    "nodemailer": "^8.0.7",
    "validator": "^13.15.35"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "html",
      "lcov"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 85,
        "statements": 85
      }
    },
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/app.js",
      "!src/server.js",
      "!src/utils/**"
    ]
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.1.0",
    "supertest": "^7.2.2"
  }
}